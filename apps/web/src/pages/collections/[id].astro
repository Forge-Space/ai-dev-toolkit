---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import { collectionItemPath, getCatalogData, getCollections, type CollectionItem } from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const collections = await getCollections();
  return collections.map((c) => ({ params: { id: c.id }, props: { collection: c } }));
}

const catalog = await getCatalogData();
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;

type EntryLike = { name?: string; title?: string; description: string };

const entriesByKind = {
  skill: new Map(catalog.skills.map((entry) => [entry.id, entry as EntryLike])),
  server: new Map(catalog.servers.map((entry) => [entry.id, entry as EntryLike])),
  doc: new Map(catalog.docs.map((entry) => [entry.id, entry as EntryLike])),
  agent: new Map(catalog.agents.map((entry) => [entry.id, entry as EntryLike])),
  hook: new Map(catalog.hooks.map((entry) => [entry.id, entry as EntryLike])),
  command: new Map(catalog.commands.map((entry) => [entry.id, entry as EntryLike])),
  tool: new Map(catalog.tools.map((entry) => [entry.id, entry as EntryLike])),
} satisfies Record<CollectionItem["kind"], Map<string, EntryLike>>;

function entryName(entry: { name?: string; title?: string }, fallback: string) {
  return entry.name ?? entry.title ?? fallback;
}

function resolveItem(item: CollectionItem) {
  const entry = entriesByKind[item.kind].get(item.id);
  return {
    kind: item.kind,
    id: item.id,
    name: entry ? entryName(entry, item.id) : item.id,
    description: entry?.description ?? "",
    href: `${base}${collectionItemPath(item)}`,
  };
}
---
<Base title={collection.name} description={collection.description}>
  <p style="margin-bottom: 1.5rem;"><a href="../">← all collections</a></p>
  <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.6rem;">📦</span>
    <h1 style="margin: 0;">{collection.name}</h1>
    <span class="kind kind-collection">collection</span>
  </div>
  <p class="lead-muted" style="margin-bottom: 1rem;">{collection.description}</p>
  {collection.tags && collection.tags.length > 0 && (
    <div class="tags" style="margin-bottom: 1.5rem;">
      {collection.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}

  <h2>Items ({collection.items.length})</h2>
  <div class="grid">
    {collection.items.map((item) => <Card {...resolveItem(item)} />)}
  </div>
</Base>
