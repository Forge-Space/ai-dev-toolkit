---
import Base from "../../../layouts/Base.astro";
import Card from "../../../components/Card.astro";
import { getCollections } from "../../../lib/catalog.ts";
import { localizeEntries, t, localizedUrl, type Locale } from "../../../lib/i18n.ts";

const locale: Locale = "pt-br";
const collections = localizeEntries(await getCollections(), locale);
const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);
const featuredCollections = collections.slice(0, 3);
const remainingCollections = collections.slice(3);
---
<Base
  title={t("list.collections.title", locale)}
  description={t("list.collections.description", locale, { count: collections.length })}
  locale={locale}
>
  <h1>{t("list.collections.title", locale)}</h1>
  <p class="lead-muted">{t("list.collections.introLede", locale)}</p>
  <section class="hero-surface" style="margin: 1.25rem 0 1rem; display: grid; gap: 1rem;">
    <div>
      <div class="hero-surface-title">{t("list.collections.intro", locale)}</div>
      <p class="lead-muted">{t("list.collections.introLede", locale)}</p>
    </div>
    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
      {featuredCollections.map((c) => (
        <Card
          kind="collection"
          id={c.id}
          name={c.name}
          description={c.description}
          tags={c.tags ?? []}
          href={url(`collections/${c.id}/`)}
          extraTag={`${c.items.length} itens`}
        />
      ))}
    </div>
  </section>
  {remainingCollections.length > 0 && (
    <div class="grid">
      {remainingCollections.map((c) => (
        <Card
          kind="collection"
          id={c.id}
          name={c.name}
          description={c.description}
          tags={c.tags ?? []}
          href={url(`collections/${c.id}/`)}
          extraTag={`${c.items.length} itens`}
        />
      ))}
    </div>
  )}
</Base>
