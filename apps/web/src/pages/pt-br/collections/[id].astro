---
import Base from "../../../layouts/Base.astro";
import Card from "../../../components/Card.astro";
import { collectionItemPath, getCatalogData, getCollections, type CollectionItem } from "../../../lib/catalog.ts";
import { localizeEntries, localizedUrl, type Locale } from "../../../lib/i18n.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const staticLocale: Locale = "pt-br";
  const collections = localizeEntries(await getCollections(), staticLocale);
  return collections.map((collection) => ({ params: { id: collection.id }, props: { collection } }));
}

const catalog = await getCatalogData();
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);

type EntryLike = { name?: string; title?: string; description: string };

const skills = localizeEntries(catalog.skills, locale);
const servers = localizeEntries(catalog.servers, locale);
const docs = localizeEntries(catalog.docs, locale);
const agents = localizeEntries(catalog.agents, locale);
const hooks = localizeEntries(catalog.hooks, locale);
const commands = localizeEntries(catalog.commands, locale);
const tools = localizeEntries(catalog.tools, locale);

const entriesByKind = {
  skill: new Map(skills.map((entry) => [entry.id, entry as EntryLike])),
  server: new Map(servers.map((entry) => [entry.id, entry as EntryLike])),
  doc: new Map(docs.map((entry) => [entry.id, entry as EntryLike])),
  agent: new Map(agents.map((entry) => [entry.id, entry as EntryLike])),
  hook: new Map(hooks.map((entry) => [entry.id, entry as EntryLike])),
  command: new Map(commands.map((entry) => [entry.id, entry as EntryLike])),
  tool: new Map(tools.map((entry) => [entry.id, entry as EntryLike])),
} satisfies Record<CollectionItem["kind"], Map<string, EntryLike>>;

function entryName(entry: { name?: string; title?: string }, fallback: string) {
  return entry.name ?? entry.title ?? fallback;
}

function resolveItem(item: CollectionItem) {
  const entry = entriesByKind[item.kind].get(item.id);
  return {
    kind: item.kind,
    id: item.id,
    name: entry ? entryName(entry, item.id) : item.id,
    description: entry?.description ?? "",
    href: url(collectionItemPath(item)),
  };
}
---
<Base title={collection.name} description={collection.description} locale={locale}>
  <p style="margin-bottom: 1.5rem;"><a href="../">← todas as coleções</a></p>
  <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.6rem;">📦</span>
    <h1 style="margin: 0;">{collection.name}</h1>
    <span class="kind kind-collection">collection</span>
  </div>
  <p class="lead-muted" style="margin-bottom: 1rem;">{collection.description}</p>
  {collection.tags && collection.tags.length > 0 && (
    <div class="tags" style="margin-bottom: 1.5rem;">
      {collection.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}

  <h2>Itens ({collection.items.length})</h2>
  <div class="grid">
    {collection.items.map((item) => <Card {...resolveItem(item)} />)}
  </div>
</Base>
