---
interface Props {
  placeholder?: string;
  tags?: string[];
}
const { placeholder = "Search by name, description, or tag…", tags = [] } = Astro.props;
---
<div class="search-panel">
  <div class="search-wrap">
    <span class="search-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8" />
        <path d="M14 14L18 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </span>
    <input
      id="search"
      type="search"
      autocomplete="off"
      spellcheck="false"
      placeholder={placeholder}
      aria-label={placeholder}
    />
  </div>
  {tags.length > 0 && (
    <div class="chips" id="chips">
      <button class="chip active" data-tag="" type="button">All</button>
      {tags.map((t) => (
        <button class="chip" data-tag={t} type="button">{t}</button>
      ))}
    </div>
  )}
</div>

<script is:inline>
  (function () {
    const input = document.getElementById("search");
    const chips = document.getElementById("chips");
    const cards = () => document.querySelectorAll("a.card");
    const allChipLabel = document.documentElement.lang.startsWith("pt") ? "Todos" : "All";
    let activeTag = "";
    let query = "";

    if (chips) {
      const first = chips.querySelector("button.chip[data-tag='']");
      if (first) first.textContent = allChipLabel;
    }

    function apply() {
      let visible = 0;
      cards().forEach((card) => {
        const tags = (card.dataset.tags || "").split(",");
        const text = card.dataset.search || "";
        const tagOk = !activeTag || tags.includes(activeTag);
        const qOk = !query || text.includes(query);
        const show = tagOk && qOk;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      });
      const empty = document.getElementById("empty-state");
      if (empty) empty.style.display = visible === 0 ? "" : "none";
    }

    if (input) {
      input.addEventListener("input", (e) => {
        query = e.target.value.trim().toLowerCase();
        apply();
      });
    }
    if (chips) {
      chips.addEventListener("click", (e) => {
        const btn = e.target.closest("button.chip");
        if (!btn) return;
        activeTag = btn.dataset.tag || "";
        chips.querySelectorAll("button.chip").forEach((b) => b.classList.toggle("active", b === btn));
        apply();
      });
    }
  })();
</script>
